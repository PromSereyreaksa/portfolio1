  "type": "object",
  "properties": {
    "order": {
      "type": "number"
    },
    "label": {
      "type": "string"
    },
    "value": {
      "type": "string"
    },
    "href": {
      "type": "string"
    },
    "icon": {
      "type": "string",
      "enum": [
        "github",
        "linkedin",
        "mail",
        "send"
      ]
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
