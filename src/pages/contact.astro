---
import PortfolioApp from '../components/PortfolioApp.jsx';
import { loadPortfolioContent } from '../lib/portfolioContent.js';
import BaseLayout from '../layouts/BaseLayout.astro';

const { siteData, experience, education, projects, artwork, contactMethods } =
  await loadPortfolioContent();
---

<BaseLayout
  title="Contact - Prom Sereyreaksa | Get In Touch"
  description="Contact Prom Sereyreaksa for software engineering projects, creative technology collaborations, or graphic design work. Get in touch for freelance opportunities in Cambodia."
  canonical="https://promsereyreaksa.dev/contact"
  keywords="Contact Prom Sereyreaksa, Software Engineer Contact, Creative Technologist Hire, Graphic Designer Cambodia, Freelance Developer, React Developer Contact"
  ogDescription="Contact Prom Sereyreaksa for software engineering projects, creative technology collaborations, or graphic design work."
>
  <PortfolioApp
    client:load
    initialSection="contact"
    hero={siteData.hero}
    about={siteData.about}
    education={education}
    experience={experience}
    projectsSection={siteData['projects-section']}
    projects={projects}
    artworkSection={siteData['artwork-section']}
    artwork={artwork}
    contact={siteData.contact}
    contactMethods={contactMethods}
  />
</BaseLayout>
