---
import { loadPortfolioContent } from '../lib/portfolioContent.js';
import SiteLayout from '../layouts/SiteLayout.astro';

const { siteData, education, contactMethods } = await loadPortfolioContent();
---

<SiteLayout
  title="About | Prom Sereyreaksa"
  description="About Prom Sereyreaksa, a software engineer working across product development, security-minded tooling, and calm interface design."
  canonical="https://promsereyreaksa.dev/about"
  currentPath="/about"
>
  <section class="page-header shell split">
    <div data-reveal>
      <p class="eyebrow">About</p>
      <h1 class="page-title">Builder first, detail-minded by default.</h1>
      {siteData.about.paragraphs.map((paragraph) => (
        <p class="page-lead">{paragraph}</p>
      ))}
    </div>
    <figure class="profile-panel" data-reveal style="margin:0;">
      <img
        src="/profile-2-768.webp"
        alt="Portrait of Prom Sereyreaksa"
        loading="eager"
        width="768"
        height="960"
        style="aspect-ratio:4/5;"
      />
      <figcaption class="profile-body">
        <p style="margin:0;color:var(--muted);">
          I care about how software behaves, how it reads, and how people move through it.
        </p>
      </figcaption>
    </figure>
  </section>

  <div class="shell divider"></div>

  <section class="section shell split">
    <div data-reveal>
      <p class="eyebrow">Approach</p>
      <h2 class="section-title">Good products feel obvious only after a lot of decisions.</h2>
    </div>
    <div class="story-block" data-reveal>
      <p>
        I enjoy projects where engineering, communication, and interface decisions need to work
        together. That usually means reducing noise, tightening the flow, and being honest about
        what the user actually needs to see.
      </p>
      <p>
        My background includes product work, technical teaching, and design support. That mix has
        made me care a lot about systems that are explainable, durable, and practical under real
        constraints.
      </p>
      <p>
        I am especially drawn to work around developer tooling, product infrastructure, and
        security-minded software where clarity matters as much as capability.
      </p>
    </div>
  </section>

  <div class="shell divider"></div>

  <section class="section shell">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Education</p>
      <h2 class="section-title">The formal track behind the work.</h2>
    </div>
    <div class="card-grid">
      {education.map((item) => (
        <article class="editorial-card" data-reveal>
          <div class="editorial-card-body">
            <div class="meta-row">
              <span>{item.years}</span>
            </div>
            <h3 style="margin-top:0.85rem;font-size:1.35rem;">{item.degree}</h3>
            <p class="section-copy" style="margin-top:0.6rem;">{item.school}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <div class="shell divider"></div>

  <section class="section shell">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Links</p>
      <h2 class="section-title">The usual places.</h2>
    </div>
    <div class="link-list">
      {contactMethods.map((method) => (
        <a href={method.href} data-reveal>
          <strong>{method.label}</strong>
          <span>{method.value}</span>
        </a>
      ))}
    </div>
  </section>

  <style>
    .story-block {
      display: grid;
      gap: 1rem;
      color: var(--muted);
      max-width: 42rem;
    }

    .story-block p {
      margin: 0;
    }

    .link-list {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 2rem;
    }

    .link-list a {
      display: grid;
      gap: 0.2rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      text-decoration: none;
    }

    .link-list span {
      color: var(--muted);
    }

    @media (max-width: 760px) {
      .link-list {
        grid-template-columns: 1fr;
      }
    }
  </style>
</SiteLayout>
