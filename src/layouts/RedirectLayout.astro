---
import BaseLayout from './BaseLayout.astro';

const {
  title,
  description,
  canonical,
  keywords,
  ogTitle,
  ogDescription,
  redirectTo,
  heading,
  body,
  linkLabel,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  keywords={keywords}
  ogTitle={ogTitle ?? title}
  ogDescription={ogDescription ?? description}
>
  <script is:inline define:vars={{ redirectTo }}>
    window.location.replace(redirectTo);
  </script>
  <noscript>
    <meta http-equiv="refresh" content={`0;url=${redirectTo}`} />
  </noscript>
  <main>
    <h1>{heading}</h1>
    <p>{body}</p>
    <p>Redirecting to full portfolio...</p>
    <a href={redirectTo}>{linkLabel}</a>
  </main>
</BaseLayout>
